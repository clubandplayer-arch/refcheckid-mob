{
  "name": "refcheckid-mob",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.83.0",
    "expo": "^53.0.0",
    "expo-router": "^5.1.0",
    "react": "^19.0.0",
    "react-native": "^0.79.0",
    "expo-dev-client": "~5.2.4"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^53.0.0",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": ["<rootDir>/jest.setup.ts"],
    "testPathIgnorePatterns": ["/node_modules/", "/source-of-truth/"]
